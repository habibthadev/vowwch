{
  "name": "vowwch",
  "version": "0.1.0",
  "description": "Zero-dependency runtime contracts for any JavaScript function.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/habibthadev/vowwch.git"
  },
  "homepage": "https://vowwch.vercel.app",
  "bugs": "https://github.com/habibthadev/vowwch/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "vowwch.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && pnpm build:vendor",
    "build:vendor": "node scripts/build-vendor.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "bench": "tsx benchmarks/contract.bench.ts",
    "size": "size-limit --config ../../.size-limit.json"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.1",
    "tinybench": "^6.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "vitest": "^3.2.1"
  }
}
